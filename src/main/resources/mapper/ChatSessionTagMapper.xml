<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.aiframework.chat.mapper.ChatSessionTagMapper">

    <resultMap id="BaseResultMap" type="com.example.aiframework.entity.ChatSessionTagEntity">
        <id column="id" property="id"/>
        <result column="session_id" property="sessionId"/>
        <result column="tag_name" property="tagName"/>
        <result column="tag_color" property="tagColor"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="selectBySessionId" resultMap="BaseResultMap">
        SELECT * FROM chat_session_tags WHERE session_id = #{sessionId}
    </select>

    <delete id="deleteBySessionId">
        DELETE FROM chat_session_tags WHERE session_id = #{sessionId}
    </delete>

    <select id="selectByTagName" resultMap="BaseResultMap">
        SELECT * FROM chat_session_tags WHERE tag_name = #{tagName}
    </select>

    <select id="selectAllTags" resultType="java.lang.String">
        SELECT DISTINCT tag_name FROM chat_session_tags ORDER BY tag_name
    </select>

</mapper>
