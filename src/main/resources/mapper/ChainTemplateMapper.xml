<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.aiframework.agent.mapper.ChainTemplateMapper">

    <resultMap id="BaseResultMap" type="com.example.aiframework.entity.ChainTemplateEntity">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="description" property="description"/>
        <result column="category" property="category"/>
        <result column="estimated_duration" property="estimatedDuration"/>
        <result column="difficulty" property="difficulty"/>
        <result column="is_enabled" property="isEnabled"/>
        <result column="is_builtin" property="isBuiltin"/>
        <result column="version" property="version"/>
        <result column="created_by" property="createdBy"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <!-- 查询所有启用的模板 -->
    <select id="selectAllEnabled" resultMap="BaseResultMap">
        SELECT * FROM chain_templates
        WHERE is_enabled = 1
        ORDER BY category, difficulty, estimated_duration
    </select>

    <!-- 根据分类查询模板 -->
    <select id="selectByCategory" resultMap="BaseResultMap">
        SELECT * FROM chain_templates
        WHERE category = #{category}
        AND is_enabled = 1
        ORDER BY difficulty, estimated_duration
    </select>

    <!-- 搜索模板 -->
    <select id="searchByNameOrDescription" resultMap="BaseResultMap">
        SELECT * FROM chain_templates
        WHERE is_enabled = 1
        AND (name LIKE CONCAT('%', #{keyword}, '%')
             OR description LIKE CONCAT('%', #{keyword}, '%')
             OR id LIKE CONCAT('%', #{keyword}, '%'))
        ORDER BY is_builtin DESC, difficulty
    </select>

    <!-- 获取所有分类 -->
    <select id="selectDistinctCategories" resultType="java.lang.String">
        SELECT DISTINCT category FROM chain_templates
        WHERE is_enabled = 1
        ORDER BY category
    </select>

    <!-- 增加使用次数 -->
    <update id="incrementUsageCount">
        UPDATE chain_templates
        SET usage_count = usage_count + 1
        WHERE id = #{id}
    </update>

</mapper>
