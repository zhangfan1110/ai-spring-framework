<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.aiframework.chat.mapper.ChatMessageFavoriteMapper">

    <resultMap id="BaseResultMap" type="com.example.aiframework.entity.ChatMessageFavoriteEntity">
        <id column="id" property="id"/>
        <result column="message_id" property="messageId"/>
        <result column="session_id" property="sessionId"/>
        <result column="content" property="content"/>
        <result column="note" property="note"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="selectAllOrderByTime" resultMap="BaseResultMap">
        SELECT * FROM chat_message_favorites ORDER BY create_time DESC
    </select>

    <select id="selectBySessionId" resultMap="BaseResultMap">
        SELECT * FROM chat_message_favorites WHERE session_id = #{sessionId}
    </select>

    <delete id="deleteByMessageId">
        DELETE FROM chat_message_favorites WHERE message_id = #{messageId}
    </delete>

</mapper>
